# === Required ===
# Server-Side API key from the FACEIT Developer Portal (App Studio -> Server-Side App).
# Never commit your real key.
FACEIT_API_KEY=

# === Optional ===
# Leetify public API key (leetify.com/app/developer). Improves rate limits for the
# advanced-stats feature; the server works fine WITHOUT it.
LEETIFY_API_KEY=

# PORT is provided automatically by Render at runtime. Only set locally to override
# the default 8000.
# PORT=8000

# --- Everything below is OFF by default; leave unset for a normal open deploy ---

# Protocol-level elicitation (ask-the-user prompts). Unreliable under stateless
# HTTP, so OFF by default; ambiguity is handled by returning candidate lists instead.
# ENABLE_ELICITATION=false

# Real FACEIT OAuth on the MCP endpoint. OFF by default (a broken auth handshake is
# the #1 reason Claude fails to connect, and token storage here is in-memory only —
# not production-usable without a persistent store). See README "Enabling real OAuth".
# ENABLE_FACEIT_OAUTH=false
# MCP_JWT_SECRET=            # signs FastMCP-issued JWTs (only used if OAuth enabled)
# FACEIT_OAUTH_CLIENT_ID=    # from your FACEIT OAuth app
# FACEIT_OAUTH_CLIENT_SECRET=
# PUBLIC_BASE_URL=           # e.g. https://your-service.onrender.com (Render sets RENDER_EXTERNAL_URL)
